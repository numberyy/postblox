# postblox v2 — local-first email TUI + MCP bridge.
#
# This file is a placeholder; the full schema lands with phase R1
# (SQLite + accounts) and R4 (MCP gates). For now nothing is read.

# Where postblox stores its SQLite DB and attachments.
# Defaults to $XDG_DATA_HOME/postblox.
# data_dir = "~/.local/share/postblox"

# [[accounts]]
# email     = "you@example.com"
# imap_host = "imap.fastmail.com"
# imap_port = 993
# smtp_host = "smtp.fastmail.com"
# smtp_port = 465
# auth      = "password"   # or "oauth2_google"

# [embeddings]
# url        = "http://localhost:11434"
# model      = "nomic-embed-text"
# dimension  = 768

# [mcp.gates]
# default = "require"          # auto_allow | require | deny
#
# [[mcp.gates.rule]]
# tool   = "send"
# to     = "*@myorg.com"
# action = "auto_allow"
#
# [[mcp.gates.rule]]
# tool   = "delete"
# action = "deny"
