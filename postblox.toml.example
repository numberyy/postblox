# Stalwart mail server connection
# stalwart_url = "http://localhost:8080"
# stalwart_admin_user = "admin"
# stalwart_admin_token = "your-admin-password"
# stalwart_inbound_token = "your-inbound-webhook-token"
# stalwart_smtp_host = "localhost"
# stalwart_smtp_port = 25

# Outbound SMTP relay (Mailgun, SES, Postmark, etc.)
# Bypasses direct delivery — mail goes through relay's warm IPs
# relay_host = "smtp.mailgun.org"
# relay_port = 587
# relay_username = "postmaster@mg.example.com"
# relay_password = "your-relay-password"
# relay_starttls = true

