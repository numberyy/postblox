# postblox — local-first email TUI + MCP bridge.
#
# Only the sections below are currently read by the daemon.

# Where postblox stores its SQLite DB and attachments.
# Defaults to $XDG_DATA_HOME/postblox.
# data_dir = "~/.local/share/postblox"

# [tui]
# # Startup theme for the TUI. Valid values: "light", "dark",
# # "high-contrast" (alias: "hc"). Runtime `:theme <name>` overrides
# # this in-memory only — changes are not written back to disk.
# theme = "dark"

# [secrets]
# # Default: store account secrets in the OS keyring.
# backend = "keyring"
#
# # Alternative file-backed secret store (AES-256-GCM,
# # Argon2id-derived key). Requires a non-empty passphrase.
# # backend = "file"
# # passphrase = "change me"
# # Optional: override where the encrypted secrets file lives.
# # Defaults to <data_dir>/secrets.bin.
# # path = "~/.local/share/postblox/secrets.bin"

# [[accounts]]
# email     = "you@example.com"
# imap_host = "imap.fastmail.com"
# imap_port = 993
# smtp_host = "smtp.fastmail.com"
# smtp_port = 465
# auth      = "password"   # or "oauth2_google"

# [embeddings]
# url        = "http://localhost:11434"
# model      = "nomic-embed-text"
# dimension  = 768

# [mcp.gates]
# default = "require"          # auto_allow | require | deny
#
# [[mcp.gates.rule]]
# tool   = "send"
# to     = "*@myorg.com"
# action = "auto_allow"
#
# [[mcp.gates.rule]]
# tool   = "delete"
# action = "deny"
